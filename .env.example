# ── Supabase ──────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena con los valores de tu proyecto Supabase
# https://app.supabase.com → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Feature flag ──────────────────────────────────────────────────────────────
# true  → conecta con Supabase (producción)
# false → usa localStorage + datos mock (desarrollo local sin backend)
VITE_SUPABASE_ENABLED=false
